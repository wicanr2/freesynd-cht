+namespace {
+//! Menus were laid out for a 640x400 canvas. When the canvas height differs
+//! (e.g. 480 for square-pixel CJK that isn't vertically stretched on display),
+//! map a legacy Y coordinate onto the new height so absolute positions stay
+//! proportional. X is unchanged because the width stays 640. A no-op at 400.
+constexpr int kLegacyMenuHeight = 400;
+}
+
+int Menu::mapY(int y) { return y * fs_eng::kScreenHeight / kLegacyMenuHeight; }
