+// Return the folder containing freesynd.exe as an fs::path built from the WIDE
+// module path. The ANSI GetModuleFileName mangles non-ASCII (e.g. CJK 極道梟雄)
+// folder names, and feeding that narrow string to std::filesystem throws
+// "Cannot convert character sequence" under Wine, crashing before the game
+// window opens. Keeping the path wide end-to-end avoids any lossy conversion.
+static fs::path exeFolder() {
+    wchar_t buf[2048];
+    DWORD n = GetModuleFileNameW(NULL, buf, 2048);
+    if (n == 0 || n >= 2048) {
+        return fs::path(L".");
+    }
+    return fs::path(buf).parent_path();
 }
