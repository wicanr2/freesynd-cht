     return true;
 }
 
+/*!
+ * Load a briefing from a UTF-8 text file (Chinese language pack path).
+ * Same section layout as loadBriefing — six `|`-separated sections, LF folding
+ * — but the prose is appended verbatim (it's already UTF-8) and we skip the
+ * per-byte CP437 → Unicode lookup that would corrupt multi-byte glyphs.
+ *
+ * Comment-only lines (leading '#') and blank lines before the first cost are
+ * skipped so the same file format used by translators (with header notes) just
+ * works.
+ */
+bool MissionBriefing::loadBriefingUtf8(uint8 * data, int size) {
+    char *cur = reinterpret_cast<char *>(data);
+    cur[size - 1] = 0;
+
+    // Skip leading comment ('#...') and blank lines.
+    auto skip_comments = [&]() {
+        while (*cur) {
+            if (*cur == '#') {
+                char *nl = strchr(cur, '\n');
+                if (!nl) { cur += strlen(cur); return; }
+                cur = nl + 1;
+            } else if (*cur == '\n' || *cur == '\r') {
+                cur++;
+            } else {
+                return;
+            }
+        }
+    };
+
+    skip_comments();
+
+    // Section 0: info costs (ASCII integers, LF-separated, terminated by `|`).
+    i_nb_infos_ = 0;
+    while (*cur && *cur != '|') {
+        a_info_costs_[i_nb_infos_++] = atoi(cur);
+        char *nl = strchr(cur, '\n');
+        if (!nl) break;
+        cur = nl + 1;
+    }
+    if (*cur == '|') cur += (cur[1] == '\n' ? 2 : 1);
+
+    // Section 1: enhancement costs.
+    i_nb_enhts_ = 0;
+    while (*cur && *cur != '|') {
+        a_enhts_costs_[i_nb_enhts_++] = atoi(cur);
+        char *nl = strchr(cur, '\n');
+        if (!nl) break;
+        cur = nl + 1;
+    }
+    if (*cur == '|') cur += (cur[1] == '\n' ? 2 : 1);
+
+    // Sections 2..(2 + nb_infos): briefing texts. Already UTF-8.
+    if (cur && *cur) {
+        std::string tmp(cur);
+        size_t start = 0;
+        for (int i = 0; i < i_nb_infos_ + 1; i++) {
+            std::string section;
+            std::size_t idx = tmp.find('|', start);
+            if (idx != std::string::npos) {
+                section.assign(tmp.substr(start, idx - start));
+                start = idx + ((idx + 1 < tmp.size() && tmp[idx + 1] == '\n') ? 2 : 1);
+            } else {
+                section.assign(tmp.substr(start));
+            }
+
+            if (i_nb_infos_ >= 1) {
+                utf8::append(0x000A, a_briefing_[i]);
+            }
+
+            // Mirror the LF-folding behaviour of the original CP437 path:
+            // single LF -> space, two-or-more LF -> paragraph break. We walk
+            // codepoints, not bytes, so multibyte UTF-8 sequences stay intact.
+            int nbLF = 0;
+            auto b = section.begin();
+            auto e = section.end();
+            while (b != e) {
+                try {
+                    utf8::utfchar32_t cp = utf8::next(b, e);
+                    if (cp == 0x000A) {
+                        nbLF += 1;
+                        continue;
+                    }
+                    if (nbLF > 1) {
+                        utf8::append(0x000A, a_briefing_[i]);
+                        utf8::append(0x000A, a_briefing_[i]);
+                    } else if (nbLF == 1) {
+                        utf8::append(0x0020, a_briefing_[i]);
+                    }
+                    nbLF = 0;
+                    utf8::append(cp, a_briefing_[i]);
+                } catch (const utf8::invalid_utf8&) {
+                    continue;
+                }
+            }
+        }
+    }
+
+    return true;
+}
