+/*
+ *  FreeSynd Chinese localization tests.
+ *
+ *  Verifies the UTF-8 briefing loader added for the CHINESE_TC language pack:
+ *  same `|`-separated section layout as the original CP437 path, but no per-
+ *  byte CP437 → Unicode transcoding (so multi-byte UTF-8 sequences survive).
+ */
+#include <catch2/catch_test_macros.hpp>
+
+#include <cstring>
+#include <string>
+
+#include "fs-kernel/model/missionbriefing.h"
+
+TEST_CASE("loadBriefingUtf8 parses costs and preserves UTF-8 prose", "[briefing][cjk]") {
+    // Minimal template matching the layout extract_briefings.py emits:
+    //   header comments (skipped), then 6 sections separated by `|`.
+    //   Sections 0/1 are integer costs, sections 2..5 are prose.
+    const char *src =
+        "# header comment line\n"
+        "\n"
+        "100\n"
+        "200\n"
+        "400\n"
+        "|\n"
+        "100\n"
+        "200\n"
+        "400\n"
+        "|\n"
+        "傭兵營區。\n暗殺：上校。\n"
+        "|\n"
+        "防禦更新：\n敵情報告顯示...\n"
+        "|\n"
+        "目標更新：\n上校位置已確認。\n"
+        "|\n"
+        "戰術建議：\n單一幹員即可完成此任務。\n";
+
+    // The loader writes a terminating NUL at data[size-1]; allocate +1 and copy.
+    std::string buf(src);
+    fs_knl::MissionBriefing brief;
+    REQUIRE(brief.loadBriefingUtf8(reinterpret_cast<uint8_t *>(buf.data()),
+                                   static_cast<int>(buf.size() + 1)) == true);
+
+    SECTION("info and enhancement counts match the integer-cost sections") {
+        REQUIRE(brief.nb_infos() == 3);
+        REQUIRE(brief.nb_enhts() == 3);
+        REQUIRE(brief.infoCost(0) == 100);
+        REQUIRE(brief.infoCost(1) == 200);
+        REQUIRE(brief.infoCost(2) == 400);
+        REQUIRE(brief.enhanceCost(0) == 100);
+        REQUIRE(brief.enhanceCost(1) == 200);
+        REQUIRE(brief.enhanceCost(2) == 400);
+    }
+
+    SECTION("default briefing keeps the original UTF-8 bytes (no '?' fallback)") {
+        const char *txt = brief.briefing(0);
+        REQUIRE(txt != nullptr);
+        // "傭" is U+50AD, UTF-8 E5 82 AD. A round-trip through cp437ToUnicode
+        // would smash these bytes to '?' (or worse). Detect by substring.
+        REQUIRE(std::string(txt).find("傭兵") != std::string::npos);
+    }
+
+    SECTION("each info-level briefing pulls from its own section") {
+        REQUIRE(std::string(brief.briefing(1)).find("防禦") != std::string::npos);
+        REQUIRE(std::string(brief.briefing(2)).find("目標") != std::string::npos);
+        REQUIRE(std::string(brief.briefing(3)).find("戰術") != std::string::npos);
+    }
+}
+
+// End-to-end check: load the actual shipped Chinese miss01 translation
+// straight off disk. Exercises the full path the engine takes when
+// MissionManager::loadBriefing routes CHINESE_TC through loadBriefingUtf8,
+// minus the missionmanager file-IO wrapper.
+TEST_CASE("loadBriefingUtf8 reads the shipped miss01.txt translation", "[briefing][cjk]") {
+    // CMake test runs from the build dir; the data files sit alongside the
+    // freesynd source tree. Try a few sensible relatives so the test isn't
+    // brittle to the cwd the runner picks.
+    const char *candidates[] = {
+        "data/lang/chinese-tw/miss01.txt",                       // run from repo root
+        "../../data/lang/chinese-tw/miss01.txt",                 // common build/* layout
+        "../../../data/lang/chinese-tw/miss01.txt",
+        "../../../../data/lang/chinese-tw/miss01.txt",
+    };
+    FILE *fp = nullptr;
+    for (const char *p : candidates) {
+        fp = fopen(p, "rb");
+        if (fp) break;
+    }
+    if (!fp) {
+        WARN("skip: cannot locate data/lang/chinese-tw/miss01.txt from cwd");
+        return;
+    }
+    fseek(fp, 0, SEEK_END);
+    size_t sz = static_cast<size_t>(ftell(fp));
+    fseek(fp, 0, SEEK_SET);
+    std::string buf(sz + 1, '\0');
+    REQUIRE(fread(buf.data(), 1, sz, fp) == sz);
+    fclose(fp);
+
+    fs_knl::MissionBriefing brief;
+    REQUIRE(brief.loadBriefingUtf8(
+                reinterpret_cast<uint8_t *>(buf.data()),
+                static_cast<int>(buf.size())) == true);
+
+    // miss01 ships three info costs (100/200/400) and three enh costs
+    // (100/200O/400 — the literal 'O' sentinel comes verbatim from the
+    // original game's MISS01.DAT and must survive the cost parser).
+    REQUIRE(brief.nb_infos() == 3);
+    REQUIRE(brief.nb_enhts() == 3);
+    REQUIRE(brief.infoCost(0) == 100);
+    REQUIRE(brief.infoCost(1) == 200);
+    REQUIRE(brief.infoCost(2) == 400);
+
+    // The default briefing carries the translated mission-2 prose and must
+    // survive the multi-byte UTF-8 path without being mangled by CP437
+    // transcoding. "傭兵營區" only appears in section 2.
+    std::string defBrief = brief.briefing(0);
+    REQUIRE(defBrief.find("傭兵營區") != std::string::npos);
+
+    // Each info level lands in its own slot: 防禦情報 / 目標情報 / 戰術建議.
+    REQUIRE(std::string(brief.briefing(1)).find("防禦") != std::string::npos);
+    REQUIRE(std::string(brief.briefing(2)).find("目標") != std::string::npos);
+    REQUIRE(std::string(brief.briefing(3)).find("戰術") != std::string::npos);
+}
+
+TEST_CASE("loadBriefingUtf8 skips leading comment/blank lines", "[briefing][cjk]") {
+    const char *src =
+        "# Briefing template for MISS01.DAT\n"
+        "# UTF-8 plain text.\n"
+        "\n"
+        "100\n"
+        "|\n"
+        "100\n"
+        "|\n"
+        "預設簡報。\n"
+        "|\n"
+        "情報一。\n";
+    std::string buf(src);
+    fs_knl::MissionBriefing brief;
+    REQUIRE(brief.loadBriefingUtf8(reinterpret_cast<uint8_t *>(buf.data()),
+                                   static_cast<int>(buf.size() + 1)) == true);
+    REQUIRE(brief.nb_infos() == 1);
+    REQUIRE(brief.infoCost(0) == 100);
+    REQUIRE(std::string(brief.briefing(0)).find("預設") != std::string::npos);
+}
