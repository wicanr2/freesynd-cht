+bool FontManager::loadCjkAtlas(const std::string& path, fs_eng::Palette &palette,
+                               std::unique_ptr<SpriteManager>& atlasOut,
+                               const std::vector<Font*>& fonts) {
+    FILE *fp = fopen(path.c_str(), "rb");
+    if (!fp) {
+        FSERR(Log::k_FLG_GFX, "FontManager", "loadCjkAtlas",
+              ("Cannot open CJK font pack: %s", path.c_str()));
+        return false;
+    }
+
+    char magic[8] = {0};
+    if (fread(magic, 1, 8, fp) != 8) { fclose(fp); return false; }
+
+    // Magic format: "FSCJK16\0" or "FSCJK12\0". Only the digits encode size.
+    int glyphPixSize = 0;
+    if (memcmp(magic, "FSCJK16", 7) == 0) glyphPixSize = 16;
+    else if (memcmp(magic, "FSCJK12", 7) == 0) glyphPixSize = 12;
+    else {
+        FSERR(Log::k_FLG_GFX, "FontManager", "loadCjkAtlas",
+              ("Bad magic in %s", path.c_str()));
+        fclose(fp);
+        return false;
+    }
+
+    uint8_t buf4[4];
+    if (fread(buf4, 1, 4, fp) != 4) { fclose(fp); return false; }
+    uint32_t count = fs_utl::READ_LE_UINT32(buf4);
+    if (count == 0 || count > 65536) { fclose(fp); return false; }
+
+    std::vector<uint32_t> codepoints(count);
+    for (uint32_t i = 0; i < count; ++i) {
+        if (fread(buf4, 1, 4, fp) != 4) { fclose(fp); return false; }
+        codepoints[i] = fs_utl::READ_LE_UINT32(buf4);
+    }
+
+    // 1bpp packed: 2 bytes per row, rows = glyphPixSize (upper bits unused at 12px).
+    const int bytesPerRow = 2;
+    const int packedSize = bytesPerRow * glyphPixSize;
+
+    // Unpack to 8-bit pixels. Foreground -> 252 (palette[252] must be white).
+    // Background -> 255 (transparent).
+    std::vector<std::vector<uint8_t>> pixelStores(count);
+    std::vector<SpriteManager::GlyphBitmap> bitmaps(count);
+    for (uint32_t i = 0; i < count; ++i) {
+        std::vector<uint8_t> packed(packedSize);
+        if (fread(packed.data(), 1, packedSize, fp) != static_cast<size_t>(packedSize)) {
+            fclose(fp);
+            return false;
+        }
+        auto& pix = pixelStores[i];
+        pix.assign(static_cast<size_t>(glyphPixSize) * glyphPixSize, 255);
+        for (int row = 0; row < glyphPixSize; ++row) {
+            uint16_t bits = (uint16_t(packed[row * 2]) << 8) | packed[row * 2 + 1];
+            for (int col = 0; col < glyphPixSize; ++col) {
+                // ttf2fnt packs the leftmost pixel at bit (glyphPixSize-1), not
+                // always bit15: 16px uses bit15, 12px uses bit11. Decode with the
+                // matching alignment or 12px glyphs shift right and clip.
+                if (bits & (1 << (glyphPixSize - 1 - col))) {
+                    pix[row * glyphPixSize + col] = 252; // foreground
+                }
+            }
+        }
+        bitmaps[i] = { glyphPixSize, glyphPixSize, pix.data() };
+    }
+    fclose(fp);
+
+    // Make sure palette index 252 maps to opaque white so colour modulation
+    // produces the intended tints. We touch a copy so we don't pollute the
+    // caller's palette beyond what's needed.
+    fs_eng::Palette cjkPalette = palette;
+    cjkPalette[252] = {254, 254, 254, 255};
+
+    // CJK atlas needs more than the default 512x512 to fit thousands of
+    // glyphs. 2048x2048 holds ~16384 16x16 sprites at native size, with room
+    // for the packer's per-row waste.
+    atlasOut = std::make_unique<SpriteManager>(true, 2048);
+    if (!atlasOut->loadGlyphSprites(bitmaps, cjkPalette)) {
+        atlasOut.reset();
+        FSERR(Log::k_FLG_GFX, "FontManager", "loadCjkAtlas",
+              ("loadGlyphSprites failed for %s", path.c_str()));
+        return false;
+    }
+
+    // Wire each requested font to this atlas and register every glyph.
+    for (Font *f : fonts) {
+        if (!f) continue;
+        f->setCjkSprites(atlasOut.get());
+        for (uint32_t i = 0; i < count; ++i) {
+            f->registerCjkGlyph(codepoints[i], static_cast<int>(i));
+        }
+    }
+
+    LOG(Log::k_FLG_GFX, "FontManager", "loadCjkAtlas",
+        ("Loaded %u CJK glyphs (%dpx) from %s", count, glyphPixSize, path.c_str()));
+    return true;
+}
+
+bool FontManager::loadCjkFont(const std::string& path16, const std::string& path12,
+                              fs_eng::Palette &palette) {
+    // 16px pack: big menu titles/buttons (SIZE_3/SIZE_4) + in-game + intro.
+    if (!loadCjkAtlas(path16, palette, pCjkSprites_,
+                      {menuFonts_[SIZE_3], menuFonts_[SIZE_4],
+                       pGameFont_, pIntroFont_.get()})) {
+        return false;
+    }
+
+    // 12px pack: dense small-text UI (briefings, labels, lists at SIZE_1/SIZE_2)
+    // so the Chinese sits closer to the original Latin font instead of towering
+    // over it.
+    if (!loadCjkAtlas(path12, palette, pCjkSprites12_,
+                      {menuFonts_[SIZE_1], menuFonts_[SIZE_2]})) {
+        // Fall back to the 16px pack for the small sizes so text still renders.
+        FSERR(Log::k_FLG_GFX, "FontManager", "loadCjkFont",
+              ("12px pack %s unavailable; reusing 16px pack for small fonts",
+               path12.c_str()));
+        return loadCjkAtlas(path16, palette, pCjkSprites12_,
+                            {menuFonts_[SIZE_1], menuFonts_[SIZE_2]});
+    }
+    return true;
+}
