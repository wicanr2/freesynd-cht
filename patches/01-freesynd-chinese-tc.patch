+bool SpriteManager::loadGlyphSprites(const std::vector<GlyphBitmap>& glyphs, const fs_eng::Palette &palette) {
+    if (glyphs.empty()) return false;
+
+    // Build a sorted entry list mirroring readAndSortTabEntries: tallest first,
+    // then narrowest. That's what the packer expects.
+    std::list<SpriteTabEntry> spriteList;
+    for (size_t i = 0; i < glyphs.size(); ++i) {
+        SpriteTabEntry entry{ i, 0u,
+                              static_cast<uint8_t>(glyphs[i].width),
+                              static_cast<uint8_t>(glyphs[i].height) };
+        auto it = spriteList.begin();
+        for (; it != spriteList.end(); ++it) {
+            if (it->height < entry.height ||
+                (it->height == entry.height && it->width > entry.width)) {
+                break;
+            }
+        }
+        spriteList.insert(it, entry);
+    }
+
+    spriteCount_ = static_cast<int>(glyphs.size());
+    if (sprites_) delete[] sprites_;
+    sprites_ = new Sprite[spriteCount_];
+    uint8_t *spriteBuffer = new uint8_t[textureWidth_ * textureWidth_];
+    memset(spriteBuffer, 255, textureWidth_ * textureWidth_);   // 255 = transparent
+
+    std::stack<SpriteInsert> spriteStack;
+    for (auto entry : spriteList) {
+        Sprite sprite(entry);
+        getInsertPoint(sprite, spriteStack);
+
+        // Copy pixels into the atlas. We bypass Sprite::copyToBuffer because
+        // it expects RLE/raw original-format bytes; we already have decoded
+        // 8-bit pixels in `pixels`.
+        const uint8_t *src = glyphs[entry.spriteId].pixels;
+        Point2D pos = sprite.textureLocation();
+        for (int row = 0; row < sprite.height(); ++row) {
+            uint8_t *dst = spriteBuffer + (pos.y + row) * textureWidth_ + pos.x;
+            memcpy(dst, src + row * sprite.width(), sprite.width());
+        }
+
+        SpriteInsert insert;
+        insert.insertedAt = pos;
+        insert.width = sprite.width();
+        insert.height = sprite.height();
+        spriteStack.push(insert);
+
+        sprites_[entry.spriteId] = sprite;
+    }
+
+    spritesetTexture_ = g_System.createTexture();
+    if (!spritesetTexture_->create8bitsSurfaceFromData(spriteBuffer,
+                                                      textureWidth_,
+                                                      textureWidth_, 255)) {
+        delete[] spriteBuffer;
+        return false;
+    }
+    bool ok = spritesetTexture_->setPalette(palette) &&
+              spritesetTexture_->loadTextureFromSurface();
+    delete[] spriteBuffer;
+    return ok;
+}
