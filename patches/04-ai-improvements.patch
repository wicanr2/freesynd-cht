+bool PlayerHostileBehaviourComponent::isTargetVisible(
+        Mission *pMission, PedInstance *pPed, PedInstance *pTarget) {
+    if (pTarget == NULL || !pTarget->isAlive())
+        return false;
+    int detectionRange = computeDetectionRange(pPed);
+    if (!pPed->isCloseTo(pTarget, detectionRange))
+        return false;
+    WorldPoint pedPosW(pPed->position());
+    WorldPoint targetPosW(pTarget->position());
+    return pMission->checkBlockedByTile(pedPosW, &targetPosW, false, detectionRange) == 1;
