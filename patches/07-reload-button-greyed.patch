+/*!
+ * Same as the menu drawText but tints every glyph with \a toColor (CJK glyphs
+ * have no dark/light variant, so this is the only way to "grey out" a CJK
+ * label). The white modulation is restored at the end so following menu text
+ * draws — which assume no tint — render normally.
+ */
+void MenuFont::drawText(int x, int y, const std::string& text, fs_eng::FSColor toColor, bool x2) {
+    int sc = x2 ? 2 : 1;
+    int ox = x;
+
+    std::string newText(text);
+    std::string::iterator b = newText.begin();
+    std::string::iterator e = newText.end();
+    while ( b != e ) {
+        try {
+            auto codePoint = utf8::next(b,e);
+
+            if (codePoint == 0x0020) {
+                x += defaultWidth_ * sc - sc;
+                continue;
+            }
+            if (codePoint == 0x000A) {
+                x = ox;
+                y += textHeight() - sc;
+                continue;
+            }
+
+            if (Sprite *cjk = getCjkSpriteForCodepoint(codePoint)) {
+                cjkSprites_->setColorModulation(toColor);
+                cjkSprites_->drawSprite(cjk->id(), x, y, false, x2);
+                x += cjk->width() * sc;
+                continue;
+            }
+
+            Sprite *sprite = getSpriteForCodepoint(codePoint, true);
+            if (sprite) {
+                int y_offset = 0;
+                if (codePoint == ':') {
+                    y_offset = sc;
+                } else if (codePoint == '.' || codePoint == ',' || codePoint == '-' || codePoint == '_')
+                    y_offset = defaultHeight_ *sc - sprite->height() * sc;
+                else if (codePoint == '/') {
+                    y_offset = (defaultHeight_ *sc)/2 - (sprite->height() * sc) / 2;
+                }
+                sprites_->setColorModulation(toColor);
+                sprites_->drawSprite(sprite->id(), x, y + y_offset, false, x2);
+                x += sprite->width() * sc - sc;
+            }
+        } catch (const utf8::invalid_utf8& exc) {
+            continue;
+        }
+    } //end of while
+
+    // Restore the default (white = no tint) so the next menu draw is normal.
+    fs_eng::FSColor white = {255, 255, 255, 255};
+    sprites_->setColorModulation(white);
+    cjkSprites_->setColorModulation(white);
+}
